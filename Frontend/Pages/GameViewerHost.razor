@page "/gameviewer-host"
@page "/GameViewerHost"
@using Frontend.Services
@using Frontend.Services.IService
@using Core
@implements IDisposable
@inject IGameSessionService GameSessionService
@inject LocalStorageService LocalStorage
@inject NavigationManager Navigation

<PageTitle>LeadByLead - HostPanel</PageTitle>

<main class="host-page">
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <section class="status-card warning">
            @message
        </section>
    }

    @if (session == null)
    {
        <section class="status-card">
            Henter spildata...
        </section>
    }
    else if (session.State == GameState.Finished ||
             session.CurrentQuestionIndex >= session.Questions.Count)
    {
        <section class="finished-card">
            <span>🎉</span>
            <h1>Spillet er færdigt</h1>

            <p>Samlet status</p>

            @if (latestStateByPlayer.Count == 0)
            {
                <div class="status-card">
                    Ingen spillerresultater fundet.
                </div>
            }
            else
            {
                <div class="player-result-list">
                    @foreach (var item in latestStateByPlayer)
                    {
                        <article class="player-result-card">
                            <h3>@item.Name</h3>
                            <strong>@FormatNumber(CalculateGroupAverage(item))</strong>
                        </article>
                    }
                </div>
            }

            <button @onclick="DeleteAndGoHome">
                Slet spil
            </button>

            <button @onclick="StartNewGame">
                Start nyt spil
            </button>
        </section>
    }
    else if (session.QuestionPhase == QuestionPhase.Results)
    {
        <section class="host-shell">
            <header class="host-header">
                <div>
                    <span class="eyebrow">Resultater</span>

                    <h1>Spørgsmål @(session.CurrentQuestionIndex + 1)</h1>

                    <p>@currentQuestion?.Text</p>
                </div>

                <div class="host-actions">
                    <button class="next-button" @onclick="NextQuestion">
                        @(session.CurrentQuestionIndex + 1 >= session.Questions.Count
                            ? "Afslut spil"
                            : "Næste spørgsmål")
                    </button>

                    <button class="end-button" @onclick="FinishGame">
                        Afslut
                    </button>
                </div>
            </header>

            <section class="panel">
                <div class="panel-title-row">
                    <h2>Status på spillere</h2>
                    <span>@GetAnsweredPlayerCount() / @session.Players.Count har svaret</span>
                </div>

                <div class="score-table">
                    @foreach (var player in session.Players)
                    {
                        var state = GetCurrentStateForPlayer(player.Id);

                        <div class="score-row @(state == null ? "empty" : "")">
                            <span class="player-name">@player.Name</span>
                            <strong>@(state == null ? "Har ikke svaret" : "Har svaret")</strong>
                        </div>
                    }
                </div>
            </section>

            <section class="panel">
                <div class="panel-title-row">
                    <h2>Påvirkning af spillernes grupper</h2>
                    <span>@playerStates.Count spillere</span>
                </div>

                @if (playerStates.Count == 0)
                {
                    <div class="status-card">
                        Ingen spillerresultater blev indsendt.
                    </div>
                }
                else
                {
                    <div class="player-result-list">
                        @foreach (var state in playerStates)
                        {
                            <article class="player-result-card">
                                <h3>@state.Name</h3>

                                @if (state.LatestResults.Count == 0)
                                {
                                    <p>Ingen ændringer.</p>
                                }
                                else
                                {
                                    @foreach (var result in state.LatestResults)
                                    {
                                        <section class="host-character-result">
                                            <strong>@result.CharacterName</strong>

                                            @if (!HasAnyDifference(result))
                                            {
                                                <span>Ingen ændringer</span>
                                            }
                                            else
                                            {
                                                <div class="host-change-list">
                                                    @ResultRow("Motivation", result.Before.TjenesteMotivation, result.After.TjenesteMotivation)
                                                    @ResultRow("Stress", result.Before.Stress, result.After.Stress)
                                                    @ResultRow("Social", result.Before.Sociallyst, result.After.Sociallyst)
                                                    @ResultRow("Tillid", result.Before.Tillid, result.After.Tillid)
                                                </div>
                                            }
                                        </section>
                                    }
                                }
                            </article>
                        }
                    </div>
                }
            </section>
        </section>
    }
    else
    {
        <section class="host-shell">
            <header class="host-header">
                <div>
                    <span class="eyebrow">Host live</span>

                    <h1>
                        Spørgsmål @(session.CurrentQuestionIndex + 1) /
                        @session.Questions.Count
                    </h1>

                    <p>@currentQuestion?.Text</p>
                </div>

                <div class="host-actions">
                    <button class="next-button"
                            @onclick="ShowResults"
                            disabled="@(session.Players.Count == 0)">
                        Vis resultater
                    </button>

                    @if (GetAnsweredPlayerCount() < session.Players.Count)
                    {
                        <small>
                            Ikke alle har svaret:
                            @GetAnsweredPlayerCount() / @session.Players.Count
                        </small>
                    }

                    <button class="end-button" @onclick="FinishGame">
                        Afslut
                    </button>
                </div>
            </header>

            <section class="host-grid">
                <article class="panel answer-panel">
                    <h2>Svarmuligheder</h2>

                    <p>
                        Spillerne skal vælge @currentQuestion?.RequiredSelections.
                    </p>

                    <div class="answer-list">
                        @if (currentQuestion != null)
                        {
                            @foreach (var option in currentQuestion.AnswerOptions.Select((value, index) => new { value, index }))
                            {
                                <div class="answer-card answer-@option.index">
                                    <span>@GetAnswerIcon(option.index)</span>

                                    <div>
                                        <strong>@option.value.Text</strong>

                                        <small>
                                            @option.value.CharacterEffects.Sum(effect => effect.Changes.Count)
                                            påvirkninger
                                        </small>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </article>

                <article class="panel scoreboard-panel">
                    <div class="panel-title-row">
                        <h2>Indsendte svar</h2>

                        <span>
                            @GetAnsweredPlayerCount() / @session.Players.Count
                        </span>
                    </div>

                    <div class="score-table">
                        @foreach (var player in session.Players)
                        {
                            var answered = GetCurrentStateForPlayer(player.Id) != null;

                            <div class="score-row @(answered ? "" : "empty")">
                                <span class="player-name">@player.Name</span>
                                <strong>@(answered ? "Har svaret" : "Venter")</strong>
                            </div>
                        }
                    </div>
                </article>
            </section>
        </section>
    }
</main>

@code {
    private const string FixedSessionId = "1";

    private GameSession? session;
    private Question? currentQuestion;

    private List<PlayerState> playerStates = new();
    private List<PlayerState> allPlayerStates = new();
    private List<PlayerState> latestStateByPlayer = new();

    private string sessionId = FixedSessionId;
    private string message = "";

    private bool confirmShowResults;

    private System.Threading.Timer? pollTimer;

    protected override async Task OnInitializedAsync()
    {
        if (await LocalStorage.GetPlayerRoleAsync() != "Host")
        {
            Navigation.NavigateTo("/");
            return;
        }

        sessionId = await LocalStorage.GetCurrentSessionIdAsync();

        if (string.IsNullOrWhiteSpace(sessionId))
            sessionId = FixedSessionId;

        await LocalStorage.SetCurrentSessionIdAsync(sessionId);

        await RefreshSession();

        if (session == null)
        {
            await LocalStorage.SetNavigationMessageAsync(
                "Der findes ingen aktiv host-session.");

            Navigation.NavigateTo("/");
            return;
        }

        pollTimer = new System.Threading.Timer(
            async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await RefreshSession();
                    StateHasChanged();
                });
            },
            null,
            TimeSpan.Zero,
            TimeSpan.FromSeconds(2));
    }

    private async Task RefreshSession()
    {
        session = await GameSessionService.GetSessionAsync(sessionId);

        if (session == null)
            return;

        currentQuestion =
            session.CurrentQuestionIndex < session.Questions.Count
                ? session.Questions[session.CurrentQuestionIndex]
                : null;

        allPlayerStates =
            await GameSessionService.GetPlayerStatesAsync(sessionId);

        playerStates = allPlayerStates
            .Where(state =>
                state.CurrentQuestionIndex ==
                session.CurrentQuestionIndex)
            .ToList();

        latestStateByPlayer = session.Players
            .Select(player =>
                allPlayerStates
                    .Where(state => state.PlayerId == player.Id)
                    .OrderByDescending(state => state.CurrentQuestionIndex)
                    .FirstOrDefault())
            .Where(state => state != null)
            .Cast<PlayerState>()
            .ToList();
    }

    private PlayerState? GetCurrentStateForPlayer(string playerId)
    {
        return playerStates.FirstOrDefault(
            state =>
                state.PlayerId == playerId &&
                state.CurrentQuestionIndex ==
                session?.CurrentQuestionIndex);
    }

    private int GetAnsweredPlayerCount()
    {
        if (session == null)
            return 0;

        return session.Players.Count(player =>
            GetCurrentStateForPlayer(player.Id) != null);
    }

    private async Task ShowResults()
    {
        message = "";

        if (session == null)
            return;

        if (GetAnsweredPlayerCount() < session.Players.Count)
        {
            message =
                $"Ikke alle har svaret endnu: {GetAnsweredPlayerCount()} / {session.Players.Count}. " +
                "Tryk igen hvis du stadig vil vise resultater.";

            if (!confirmShowResults)
            {
                confirmShowResults = true;
                return;
            }
        }

        confirmShowResults = false;

        var success =
            await GameSessionService.AdvanceQuestionAsync(sessionId);

        if (!success)
        {
            message = GameSessionService.LastError;
            return;
        }

        await RefreshSession();
    }

    private async Task NextQuestion()
    {
        message = "";

        if (session == null)
            return;

        var success =
            await GameSessionService.AdvanceQuestionAsync(sessionId);

        if (!success)
        {
            message = GameSessionService.LastError;
            return;
        }

        await RefreshSession();
    }

    private async Task FinishGame()
    {
        message = "";

        var success =
            await GameSessionService.FinishSessionAsync(sessionId);

        if (!success)
        {
            message = GameSessionService.LastError;
            return;
        }

        await RefreshSession();
    }

    private async Task DeleteAndGoHome()
    {
        await GameSessionService.DeleteSessionAsync(sessionId);
        await LocalStorage.ClearAllAsync();

        Navigation.NavigateTo("/");
    }

    private async Task StartNewGame()
    {
        await GameSessionService.DeleteSessionAsync(sessionId);
        await LocalStorage.ClearAllAsync();
        await LocalStorage.SetPlayerRoleAsync("Host");

        Navigation.NavigateTo("/gameeditor");
    }

    private static bool HasAnyDifference(CharacterResult result)
    {
        return
            result.Before.TjenesteMotivation != result.After.TjenesteMotivation ||
            result.Before.Stress != result.After.Stress ||
            result.Before.Sociallyst != result.After.Sociallyst ||
            result.Before.Tillid != result.After.Tillid;
    }

    private RenderFragment ResultRow(string label, int before, int after)
    {
        if (before == after)
            return @<text></text>;

        var difference = after - before;
        var sign = difference > 0 ? "+" : "";

        return @<div class="host-change-row">
            <span>@label</span>
            <span>@before → @after</span>
            <strong>@sign@difference</strong>
        </div>;
    }

    private static double CalculateGroupAverage(PlayerState state)
    {
        if (state.Characters.Count == 0)
            return 0;

        var motivation = state.Characters.Average(
            item => item.CurrentStats.TjenesteMotivation);

        var stress = state.Characters.Average(
            item => item.CurrentStats.Stress);

        var social = state.Characters.Average(
            item => item.CurrentStats.Sociallyst);

        var trust = state.Characters.Average(
            item => item.CurrentStats.Tillid);

        return (motivation + (100 - stress) + social + trust) / 4;
    }

    private static string GetAnswerIcon(int index)
    {
        return NatoPhonetic.GetLabel(index);
    }

    private static string FormatNumber(double value)
    {
        return ((int)Math.Round(value)).ToString();
    }

    public void Dispose()
    {
        pollTimer?.Dispose();
    }
}