@page "/gameeditor"
@using Frontend.Services
@using Frontend.Services.IService
@using Core
@inject ICharacterService CharacterService
@inject IQuestionsService QuestionService
@inject IGameSessionService GameSessionService
@inject LocalStorageService LocalStorage
@inject NavigationManager Navigation

<PageTitle>Game Editor - LeadingByLead</PageTitle>

<main class="editor-page">
    @if (string.IsNullOrEmpty(currentSessionId))
    {
        <section class="editor-hero">
            <div>
                <span class="eyebrow">Host panel</span>
                <h1>Byg dit spil</h1>
                <p>
                    Vælg de spørgsmål og characters, der skal indgå,
                    eller opret nye direkte fra editoren.
                </p>
            </div>

            <button class="ghost-button" @onclick="GoHome">
                ← Tilbage
            </button>
        </section>

        <section class="editor-grid">
            <article class="editor-panel questions-panel">
                <header class="panel-header">
                    <div>
                        <span class="panel-kicker">Spørgsmål</span>
                        <h2>Alle spørgsmål</h2>
                    </div>

                    <button class="primary-button"
                            @onclick="() => OpenQuestionModal(null)">
                        + Opret spørgsmål
                    </button>
                </header>

                <div class="selected-count">
                    Valgt til spil:
                    <strong>@selectedQuestions.Count</strong>
                </div>

                @if (allQuestions == null)
                {
                    <div class="empty-state">
                        Henter spørgsmål...
                    </div>
                }
                else if (allQuestions.Count == 0)
                {
                    <div class="empty-state">
                        Ingen spørgsmål endnu. Opret det første spørgsmål.
                    </div>
                }
                else
                {
                    <div class="item-list">
                        @foreach (var questionItem in allQuestions
                            .Select((value, index) => new { value, index }))
                        {
                            var question = questionItem.value;
                            var selected = selectedQuestions.Any(
                                selectedQuestion =>
                                    selectedQuestion.Id == question.Id);

                            <div class="list-card @(selected ? "is-selected" : "")">
                                <span class="list-number">
                                    @(questionItem.index + 1)
                                </span>

                                <label class="select-zone">
                                    <input type="checkbox"
                                           checked="@selected"
                                           @onchange="eventArgs =>
                                               ToggleQuestion(
                                                   question,
                                                   (bool)eventArgs.Value!)" />

                                    <span class="check-ui"></span>
                                </label>

                                <div class="item-main"
                                     @onclick="() =>
                                         ToggleQuestion(question, !selected)">
                                    <h3>@question.Text</h3>

                                    <p>
                                        @question.AnswerOptions.Count svarmuligheder
                                    </p>
                                </div>

                                <div class="item-actions">
                                    <button class="small-button blue"
                                            @onclick="() =>
                                                OpenQuestionModal(question)">
                                        Rediger
                                    </button>

                                    <button class="small-button red"
                                            @onclick="() =>
                                                DeleteQuestion(question.Id)">
                                        Slet
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </article>

            <article class="editor-panel characters-panel">
                <header class="panel-header">
                    <div>
                        <span class="panel-kicker">Characters</span>
                        <h2>Alle characters</h2>
                    </div>

                    <button class="primary-button"
                            @onclick="() => OpenCharacterModal(null)">
                        + Opret character
                    </button>
                </header>

                <div class="selected-count">
                    Valgt til spil:
                    <strong>@selectedCharacters.Count</strong>
                </div>

                @if (allCharacters == null)
                {
                    <div class="empty-state">
                        Henter characters...
                    </div>
                }
                else if (allCharacters.Count == 0)
                {
                    <div class="empty-state">
                        Ingen characters endnu. Opret den første character.
                    </div>
                }
                else
                {
                    <div class="item-list">
                        @foreach (var characterItem in allCharacters
                            .Select((value, index) => new { value, index }))
                        {
                            var character = characterItem.value;
                            var selected = selectedCharacters.Any(
                                selectedCharacter =>
                                    selectedCharacter.Id == character.Id);

                            <div class="list-card @(selected ? "is-selected" : "")">
                                <span class="list-number">
                                    @(characterItem.index + 1)
                                </span>

                                <label class="select-zone">
                                    <input type="checkbox"
                                           checked="@selected"
                                           @onchange="eventArgs =>
                                               ToggleCharacter(
                                                   character,
                                                   (bool)eventArgs.Value!)" />

                                    <span class="check-ui"></span>
                                </label>

                                <div class="item-main"
                                     @onclick="() =>
                                         ToggleCharacter(character, !selected)">
                                    <h3>@character.Name</h3>

                                    <p>@character.Description</p>

                                    <div class="stat-chips">
                                        <span>
                                            Motivation
                                            @character.BaseStats.TjenesteMotivation
                                        </span>

                                        <span>
                                            Stress
                                            @character.BaseStats.Stress
                                        </span>

                                        <span>
                                            Social
                                            @character.BaseStats.Sociallyst
                                        </span>

                                        <span>
                                            Tillid
                                            @character.BaseStats.Tillid
                                        </span>
                                    </div>
                                </div>

                                <div class="item-actions">
                                    <button class="small-button blue"
                                            @onclick="() =>
                                                OpenCharacterModal(character)">
                                        Rediger
                                    </button>

                                    <button class="small-button red"
                                            @onclick="() =>
                                                DeleteCharacter(character.Id)">
                                        Slet
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </article>
        </section>

        <section class="create-bar">
            <div>
                <strong>@selectedQuestions.Count spørgsmål</strong>
                <span>og</span>
                <strong>@selectedCharacters.Count characters</strong>
                <span>valgt</span>
            </div>

            <button class="start-button"
                    @onclick="CreateGame"
                    disabled="@(
                        selectedCharacters.Count == 0 ||
                        selectedQuestions.Count == 0)">
                Opret spil
            </button>
        </section>
    }
    else
    {
        <section class="created-screen">
            <div class="created-card">
                <h1>Spil oprettet</h1>

                <p>Del session ID'et med spillerne.</p>

                <div class="session-code">
                    @currentSessionId
                </div>

                <div class="created-meta">
                    <span>@selectedQuestions.Count spørgsmål</span>
                    <span>@selectedCharacters.Count characters</span>
                </div>

                <button class="start-button full"
                        @onclick="GoToWaitingArea">
                    Gå til venteområde →
                </button>
            </div>
        </section>
    }
</main>

<CharacterModal Visible="@showCharacterModal"
                VisibleChanged="@(async value =>
                {
                    showCharacterModal = value;

                    if (!value)
                        await RefreshLists();
                })"
                Model="@editingCharacter" />

<QuestionModal Visible="@showQuestionModal"
               VisibleChanged="@(async value =>
               {
                   showQuestionModal = value;

                   if (!value)
                       await RefreshLists();
               })"
               Model="@editingQuestion"
               Characters="@(allCharacters ?? new List<Character>())" />

@code {
    private List<Character>? allCharacters;
    private List<Question>? allQuestions;

    private List<Character> selectedCharacters = new();
    private List<Question> selectedQuestions = new();

    private string currentSessionId = "";

    private bool showCharacterModal;
    private Character editingCharacter = new();

    private bool showQuestionModal;
    private Question editingQuestion = new();

    protected override async Task OnInitializedAsync()
    {
        if (LocalStorage.GetPlayerRole() != "Host")
        {
            Navigation.NavigateTo("/");
            return;
        }

        currentSessionId = LocalStorage.GetCurrentSessionId();

        await RefreshLists();
    }

    private async Task RefreshLists()
    {
        try
        {
            allCharacters =
                await CharacterService.GetAllCharactersAsync();

            allQuestions =
                await QuestionService.GetAllQuestionsAsync();

            selectedCharacters = selectedCharacters
                .Where(selected =>
                    allCharacters.Any(character =>
                        character.Id == selected.Id))
                .ToList();

            selectedQuestions = selectedQuestions
                .Where(selected =>
                    allQuestions.Any(question =>
                        question.Id == selected.Id))
                .ToList();

            StateHasChanged();
        }
        catch
        {
        }
    }

    private void OpenCharacterModal(Character? character)
    {
        editingCharacter = character == null
            ? new Character
            {
                BaseStats = new BaseStats(),
                CurrentStats = new CurrentStats()
            }
            : CloneCharacter(character);

        showCharacterModal = true;
    }

    private void OpenQuestionModal(Question? question)
    {
        editingQuestion = question == null
            ? new Question
            {
                AnswerOptions = new List<AnswerOption>()
            }
            : CloneQuestion(question);

        showQuestionModal = true;
    }

    private async Task DeleteCharacter(string id)
    {
        await CharacterService.DeleteCharacterAsync(id);

        selectedCharacters = selectedCharacters
            .Where(character => character.Id != id)
            .ToList();

        await RefreshLists();
    }

    private async Task DeleteQuestion(string id)
    {
        await QuestionService.DeleteQuestionAsync(id);

        selectedQuestions = selectedQuestions
            .Where(question => question.Id != id)
            .ToList();

        await RefreshLists();
    }

    private void ToggleCharacter(
        Character character,
        bool isChecked)
    {
        if (isChecked &&
            selectedCharacters.All(item => item.Id != character.Id))
        {
            selectedCharacters.Add(character);
        }

        if (!isChecked)
        {
            selectedCharacters = selectedCharacters
                .Where(item => item.Id != character.Id)
                .ToList();
        }
    }

    private void ToggleQuestion(
        Question question,
        bool isChecked)
    {
        if (isChecked &&
            selectedQuestions.All(item => item.Id != question.Id))
        {
            selectedQuestions.Add(question);
        }

        if (!isChecked)
        {
            selectedQuestions = selectedQuestions
                .Where(item => item.Id != question.Id)
                .ToList();
        }
    }

    private async Task CreateGame()
    {
        if (selectedCharacters.Count == 0 ||
            selectedQuestions.Count == 0)
        {
            return;
        }

        var session = new GameSession
        {
            Host = new Player
            {
                Name = "Host",
                Role = PlayerRole.Host
            },

            Characters = selectedCharacters
                .Select(CloneCharacter)
                .ToList(),

            Questions = selectedQuestions
                .Select(CloneQuestion)
                .ToList(),

            State = GameState.Lobby,
            Players = new List<Player>(),
            CurrentQuestionIndex = 0
        };

        var created =
            await GameSessionService.CreateSessionAsync(session);

        if (created?.Id == null)
            return;

        currentSessionId = created.Id;

        LocalStorage.SetCurrentSessionId(created.Id);

        LocalStorage.SavePlayerCharacters(
            created.Characters ?? session.Characters);
    }

    private static Character CloneCharacter(Character character)
    {
        var baseStats = character.BaseStats ?? new BaseStats();
        var currentStats = character.CurrentStats ?? new CurrentStats();

        return new Character
        {
            Id = character.Id,
            Name = character.Name,
            Description = character.Description,

            BaseStats = new BaseStats
            {
                TjenesteMotivation =
                    baseStats.TjenesteMotivation,

                Stress =
                    baseStats.Stress,

                Sociallyst =
                    baseStats.Sociallyst,

                Tillid =
                    baseStats.Tillid
            },

            CurrentStats = new CurrentStats
            {
                TjenesteMotivation =
                    currentStats.TjenesteMotivation,

                Stress =
                    currentStats.Stress,

                Sociallyst =
                    currentStats.Sociallyst,

                Tillid =
                    currentStats.Tillid
            }
        };
    }

    private static Question CloneQuestion(Question question)
    {
        return new Question
        {
            Id = question.Id,
            Text = question.Text,

            AnswerOptions = question.AnswerOptions?
                .Select(option => new AnswerOption
                {
                    Id = option.Id,
                    Text = option.Text,

                    CharacterEffects = option.CharacterEffects?
                        .Select(effect => new CharacterEffect
                        {
                            CharacterId = effect.CharacterId,

                            Changes = effect.Changes?
                                .Select(change => new StatChange
                                {
                                    StatName = change.StatName,
                                    Amount = change.Amount
                                })
                                .ToList() ?? new List<StatChange>()
                        })
                        .ToList() ?? new List<CharacterEffect>()
                })
                .ToList() ?? new List<AnswerOption>()
        };
    }

    private void GoToWaitingArea()
    {
        Navigation.NavigateTo("/waiting-area");
    }

    private void GoHome()
    {
        LocalStorage.ClearAll();
        Navigation.NavigateTo("/");
    }
}