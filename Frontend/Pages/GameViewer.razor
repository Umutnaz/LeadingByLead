@page "/gameviewer"
@using Frontend.Services
@using Frontend.Services.IService
@using Core
@implements IDisposable
@inject IGameSessionService GameSessionService
@inject LocalStorageService LocalStorage
@inject NavigationManager Navigation

<PageTitle>LeadByLead - Game</PageTitle>

<main class="game-page">
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <section class="status-card warning">
            @message
        </section>
    }

    @if (session == null)
    {
        <section class="status-card warning">
            Henter spildata...
        </section>
    }
    else if (session.State == GameState.Finished)
    {
        <section class="finished-card">
            <span>🎉</span>
            <h1>Spillet er færdigt</h1>

            <p>Dit gruppegennemsnit</p>

            <strong>@FormatNumber(CalculateGroupAverage())</strong>

            <button class="primary-button result-action-button" @onclick="GoHome">
                Gå hjem
            </button>
        </section>
    }
    else if (session.State != GameState.Running)
    {
        <section class="status-card info">
            Spillet er ikke startet endnu. Vent på hosten.
        </section>
    }
    else if (session.QuestionPhase == QuestionPhase.Results)
    {
        <section class="result-screen">
            <article class="result-card">
                <span class="result-kicker">Dit resultat</span>

                <h1>Sådan blev din gruppe påvirket</h1>
                <div class="result-summary-grid">
                    <article class="summary-card personal-summary">
                        <span>Din gruppe</span>
                        <strong>@FormatNumber(CalculateGroupAverage())</strong>
                        <small>Efter dette spørgsmål</small>
                    </article>

                    <article class="summary-card overall-summary">
                        <span>Alle grupper</span>
                        <strong>@FormatNumber(CalculateAllGroupsAverage())</strong>
                        <small>
                            Gennemsnit af @currentQuestionStates.Count grupper
                        </small>
                    </article>
                </div>
                @if (latestResults.Count == 0)
                {
                    <div class="no-results">
                        Dit seneste valg ændrede ikke gruppens værdier.
                    </div>
                }
                else
                {
                    <div class="result-list">
                        @foreach (var result in latestResults)
                        {
                            <article class="character-result">
                                <h2>@result.CharacterName</h2>

                                @if (!HasAnyDifference(result))
                                {
                                    <p class="no-character-change">
                                        Ingen ændringer
                                    </p>
                                }
                                else
                                {
                                    <div class="change-list">
                                        @ResultRow("Tjenestemotivation", result.Before.TjenesteMotivation, result.After.TjenesteMotivation)
                                        @ResultRow("Stress", result.Before.Stress, result.After.Stress)
                                        @ResultRow("Social lyst", result.Before.Sociallyst, result.After.Sociallyst)
                                        @ResultRow("Tillid", result.Before.Tillid, result.After.Tillid)
                                    </div>
                                }
                            </article>
                        }
                    </div>
                }

                <div class="wait-banner">
                    Vent på at hosten åbner næste spørgsmål.
                </div>
            </article>
        </section>
    }
    else if (currentQuestion == null)
    {
        <section class="finished-card">
            <span>🎉</span>
            <h1>Alle spørgsmål er gennemført</h1>
            <p>Vent på at hosten afslutter spillet.</p>
        </section>
    }
    else
    {
        <section class="game-layout">
            <article class="question-card">
                <div class="question-topline">
                    <span>
                        Spørgsmål @(session.CurrentQuestionIndex + 1) /
                        @session.Questions.Count
                    </span>

                    <span>Vælg @currentQuestion.RequiredSelections</span>
                </div>

                <h1>@currentQuestion.Text</h1>

                <div class="answer-grid">
                    @for (var i = 0; i < currentQuestion.AnswerOptions.Count; i++)
                    {
                        var index = i;
                        var answer = currentQuestion.AnswerOptions[index];
                        var selected = selectedAnswerIds.Contains(answer.Id);

                        <button class="answer-button answer-@index @(selected ? "selected" : "")"
                                @onclick="() => ToggleAnswer(answer)"
                                disabled="@hasAnswered">
                            <span class="answer-shape">@GetAnswerIcon(index)</span>
                            <span>@answer.Text</span>
                        </button>
                    }
                </div>

                @if (!hasAnswered)
                {
                    <button class="submit-answer-button"
                            @onclick="SubmitAnswers"
                            disabled="@(selectedAnswerIds.Count != currentQuestion.RequiredSelections)">
                        Bekræft @selectedAnswerIds.Count / @currentQuestion.RequiredSelections
                    </button>
                }
                else
                {
                    <div class="wait-banner">
                        Svar indsendt. Vent på hosten...
                    </div>
                }
            </article>

            <aside class="stats-panel">
                <header>
                    <span>Din gruppe</span>
                    <strong>@FormatNumber(CalculateGroupAverage())</strong>
                </header>

                @if (playerCharacters.Count == 0)
                {
                    <div class="empty-state">
                        Ingen characters fundet.
                    </div>
                }
                else
                {
                    <div class="stat-list">
                        @StatBar("Motivation", GetAverageStat(c => c.CurrentStats.TjenesteMotivation), "motivation")
                        @StatBar("Stress", GetAverageStat(c => c.CurrentStats.Stress), "stress")
                        @StatBar("Sociallyst", GetAverageStat(c => c.CurrentStats.Sociallyst), "social")
                        @StatBar("Tillid", GetAverageStat(c => c.CurrentStats.Tillid), "trust")
                    </div>

                    <div class="mini-characters">
                        @foreach (var character in playerCharacters)
                        {
                            <div>
                                <strong>@character.Name</strong>
                                <span>@FormatNumber(CalculateCharacterAverage(character))</span>
                            </div>
                        }
                    </div>
                }
            </aside>
        </section>
    }
</main>

@code {
    private GameSession? session;
    private Question? currentQuestion;

    private List<Character> playerCharacters = new();
    private List<CharacterResult> latestResults = new();
    private List<PlayerState> currentQuestionStates = new();
    private HashSet<string> selectedAnswerIds = new();

    private bool hasAnswered;
    private int lastQuestionIndex = -1;

    private string sessionId = "";
    private string playerId = "";
    private string playerName = "";
    private string message = "";

    private System.Threading.Timer? pollTimer;

    protected override async Task OnInitializedAsync()
    {
        if (await LocalStorage.GetPlayerRoleAsync() != "Player")
        {
            Navigation.NavigateTo("/");
            return;
        }

        sessionId = await LocalStorage.GetCurrentSessionIdAsync();
        playerId = await LocalStorage.GetPlayerIdAsync();
        playerName = await LocalStorage.GetPlayerNameAsync();

        if (string.IsNullOrWhiteSpace(sessionId))
        {
            await LocalStorage.SetNavigationMessageAsync(
                "Du skal joine et spil først.");

            Navigation.NavigateTo("/waiting-area");
            return;
        }

        if (string.IsNullOrWhiteSpace(playerId))
        {
            await LocalStorage.SetNavigationMessageAsync(
                "Din spiller mangler. Join spillet igen.");

            Navigation.NavigateTo("/waiting-area");
            return;
        }

        playerCharacters = await LocalStorage.GetPlayerCharactersAsync();

        await RefreshSession();

        pollTimer = new System.Threading.Timer(
            async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await RefreshSession();
                    StateHasChanged();
                });
            },
            null,
            TimeSpan.Zero,
            TimeSpan.FromSeconds(2));
    }

    private async Task RefreshSession()
    {
        session = await GameSessionService.GetSessionAsync(sessionId);

        if (session == null)
        {
            pollTimer?.Dispose();

            await LocalStorage.ClearPlayerSessionDataAsync();
            await LocalStorage.SetNavigationMessageAsync(
                "Sessionen findes ikke længere.");

            Navigation.NavigateTo("/");
            return;
        }

        var stillInSession =
            session.Players.Any(player => player.Id == playerId);

        if (!stillInSession && session.State != GameState.Finished)
        {
            pollTimer?.Dispose();

            await LocalStorage.ClearPlayerSessionDataAsync();
            await LocalStorage.SetNavigationMessageAsync(
                "Du er blevet fjernet fra spillet af hosten.");

            Navigation.NavigateTo("/");
            return;
        }

        if (playerCharacters.Count == 0 &&
            session.Characters.Count > 0)
        {
            playerCharacters =
                session.Characters.Select(CloneCharacter).ToList();

            await LocalStorage.SavePlayerCharactersAsync(playerCharacters);
        }

        currentQuestion =
            session.CurrentQuestionIndex < session.Questions.Count
                ? session.Questions[session.CurrentQuestionIndex]
                : null;

        if (lastQuestionIndex != session.CurrentQuestionIndex)
        {
            lastQuestionIndex = session.CurrentQuestionIndex;
            selectedAnswerIds.Clear();
            latestResults.Clear();
            hasAnswered = false;

            await LocalStorage.SetCurrentQuestionIndexAsync(
                session.CurrentQuestionIndex);

            await RestoreOwnStateForCurrentQuestion();
        }

        if (session.QuestionPhase == QuestionPhase.Results)
        {
            await RestoreOwnStateForCurrentQuestion();
        }
    }

    private async Task RestoreOwnStateForCurrentQuestion()
    {
        var states =
            await GameSessionService.GetPlayerStatesAsync(sessionId);

        currentQuestionStates = states
            .Where(state =>
                state.CurrentQuestionIndex ==
                session?.CurrentQuestionIndex)
            .ToList();

        var ownState = currentQuestionStates.FirstOrDefault(
            state => state.PlayerId == playerId);

        if (ownState == null)
            return;

        latestResults = ownState.LatestResults;
        hasAnswered = true;

        if (ownState.Characters.Count > 0)
        {
            playerCharacters = session!.Characters
                .Select(character =>
                {
                    var snapshot = ownState.Characters.FirstOrDefault(
                        item => item.CharacterId == character.Id);

                    var cloned = CloneCharacter(character);

                    if (snapshot != null)
                        cloned.CurrentStats = CopyStats(snapshot.CurrentStats);

                    return cloned;
                })
                .ToList();

            await LocalStorage.SavePlayerCharactersAsync(playerCharacters);
        }
    }

    private void ToggleAnswer(AnswerOption answer)
    {
        if (hasAnswered || currentQuestion == null)
            return;

        if (selectedAnswerIds.Contains(answer.Id))
        {
            selectedAnswerIds.Remove(answer.Id);
            return;
        }

        if (selectedAnswerIds.Count >= currentQuestion.RequiredSelections)
            return;

        selectedAnswerIds.Add(answer.Id);
    }

    private async Task SubmitAnswers()
    {
        message = "";

        if (hasAnswered ||
            currentQuestion == null ||
            selectedAnswerIds.Count != currentQuestion.RequiredSelections)
        {
            return;
        }

        hasAnswered = true;

        var before = playerCharacters.ToDictionary(
            character => character.Id,
            character => CopyStats(character.CurrentStats));

        var selectedAnswers = currentQuestion.AnswerOptions
            .Where(answer => selectedAnswerIds.Contains(answer.Id))
            .ToList();

        foreach (var answer in selectedAnswers)
            ApplyCharacterEffects(playerCharacters, answer);

        latestResults = playerCharacters
            .Select(character => new CharacterResult
            {
                CharacterId = character.Id,
                CharacterName = character.Name,
                Before = before.TryGetValue(character.Id, out var oldStats)
                    ? oldStats
                    : new CurrentStats(),
                After = CopyStats(character.CurrentStats)
            })
            .ToList();

        await LocalStorage.SavePlayerCharactersAsync(playerCharacters);

        await LocalStorage.AddAnsweredQuestionAsync(
            currentQuestion.Id,
            selectedAnswerIds);

        var playerState = new PlayerState
        {
            PlayerId = playerId,
            Name = playerName,
            CurrentQuestionIndex = session?.CurrentQuestionIndex ?? 0,
            LatestQuestionId = currentQuestion.Id,
            Characters = BuildCharacterSnapshots(),
            LatestResults = latestResults,
            Answers = new List<AnswerRecord>
            {
                new()
                {
                    QuestionId = currentQuestion.Id,
                    AnswerIds = selectedAnswerIds.ToList()
                }
            }
        };

        var success =
            await GameSessionService.PostPlayerStateAsync(
                sessionId,
                playerState);

        if (!success)
        {
            message = GameSessionService.LastError;
            hasAnswered = false;
        }
    }

    private static void ApplyCharacterEffects(List<Character> characters, AnswerOption option)
    {
        foreach (var effect in option.CharacterEffects)
        {
            var character = characters.FirstOrDefault(item => item.Id == effect.CharacterId);

            if (character == null)
                continue;

            foreach (var change in effect.Changes)
                ApplyStatChange(character, change);
        }
    }

    private static void ApplyStatChange(Character character, StatChange change)
    {
        var amount = Math.Clamp(change.Amount, -100, 100);

        switch (change.StatName)
        {
            case nameof(CurrentStats.TjenesteMotivation):
                character.CurrentStats.TjenesteMotivation =
                    Math.Clamp(character.CurrentStats.TjenesteMotivation + amount, 0, 100);
                break;

            case nameof(CurrentStats.Stress):
                character.CurrentStats.Stress =
                    Math.Clamp(character.CurrentStats.Stress + amount, 0, 100);
                break;

            case nameof(CurrentStats.Sociallyst):
                character.CurrentStats.Sociallyst =
                    Math.Clamp(character.CurrentStats.Sociallyst + amount, 0, 100);
                break;

            case nameof(CurrentStats.Tillid):
                character.CurrentStats.Tillid =
                    Math.Clamp(character.CurrentStats.Tillid + amount, 0, 100);
                break;
        }
    }

    private List<CharacterSnapshot> BuildCharacterSnapshots()
    {
        return playerCharacters
            .Select(character => new CharacterSnapshot
            {
                CharacterId = character.Id,
                Name = character.Name,
                CurrentStats = CopyStats(character.CurrentStats)
            })
            .ToList();
    }

    private static CurrentStats CopyStats(CurrentStats stats)
    {
        return new CurrentStats
        {
            TjenesteMotivation = stats.TjenesteMotivation,
            Stress = stats.Stress,
            Sociallyst = stats.Sociallyst,
            Tillid = stats.Tillid
        };
    }

    private static bool HasAnyDifference(CharacterResult result)
    {
        return
            result.Before.TjenesteMotivation != result.After.TjenesteMotivation ||
            result.Before.Stress != result.After.Stress ||
            result.Before.Sociallyst != result.After.Sociallyst ||
            result.Before.Tillid != result.After.Tillid;
    }

    private RenderFragment ResultRow(string label, int before, int after)
    {
        if (before == after)
            return @<text></text>;

        var difference = after - before;
        var sign = difference > 0 ? "+" : "";

        return @<div class="change-row">
            <span>@label</span>
            <span>@before → @after</span>
            <strong>@sign@difference</strong>
        </div>;
    }

    private double GetAverageStat(Func<Character, int> selector)
    {
        return playerCharacters.Count == 0
            ? 0
            : playerCharacters.Average(selector);
    }

    private double CalculateGroupAverage()
    {
        if (playerCharacters.Count == 0)
            return 0;

        return (
            GetAverageStat(c => c.CurrentStats.TjenesteMotivation) +
            (100 - GetAverageStat(c => c.CurrentStats.Stress)) +
            GetAverageStat(c => c.CurrentStats.Sociallyst) +
            GetAverageStat(c => c.CurrentStats.Tillid)
        ) / 4;
    }

    private static double CalculateCharacterAverage(Character character)
    {
        return (
            character.CurrentStats.TjenesteMotivation +
            (100 - character.CurrentStats.Stress) +
            character.CurrentStats.Sociallyst +
            character.CurrentStats.Tillid
        ) / 4.0;
    }

    private RenderFragment StatBar(string label, double value, string className)
    {
        return @<div class="stat-row @className">
            <div>
                <span>@label</span>
                <strong>@FormatNumber(value)</strong>
            </div>

            <div class="meter">
                <span style="width: @(FormatNumber(Math.Clamp(value, 0, 100)))%"></span>
            </div>
        </div>;
    }

    private static Character CloneCharacter(Character character)
    {
        return new Character
        {
            Id = character.Id,
            Name = character.Name,
            Description = character.Description,

            BaseStats = new BaseStats
            {
                TjenesteMotivation = character.BaseStats.TjenesteMotivation,
                Stress = character.BaseStats.Stress,
                Sociallyst = character.BaseStats.Sociallyst,
                Tillid = character.BaseStats.Tillid
            },

            CurrentStats = CopyStats(character.CurrentStats)
        };
    }

    private static string GetAnswerIcon(int index)
    {
        return NatoPhonetic.GetLabel(index);
    }

    private static string FormatNumber(double value)
    {
        return ((int)Math.Round(value)).ToString();
    }

    private async Task GoHome()
    {
        await LocalStorage.ClearPlayerSessionDataAsync();
        Navigation.NavigateTo("/");
    }

    public void Dispose()
    {
        pollTimer?.Dispose();
    }
    private static double CalculateStateGroupAverage(PlayerState state)
    {
        if (state.Characters.Count == 0)
            return 0;

        var motivation = state.Characters
            .Average(character => character.CurrentStats.TjenesteMotivation);

        var stress = state.Characters
            .Average(character => character.CurrentStats.Stress);

        var social = state.Characters
            .Average(character => character.CurrentStats.Sociallyst);

        var trust = state.Characters
            .Average(character => character.CurrentStats.Tillid);

        return (
            motivation +
            (100 - stress) +
            social +
            trust
        ) / 4;
    }

    private double CalculateAllGroupsAverage()
    {
        var validStates = currentQuestionStates
            .Where(state => state.Characters.Count > 0)
            .ToList();

        return validStates.Count == 0
            ? 0
            : validStates.Average(CalculateStateGroupAverage);
    }
}