@using Core
@using Frontend.Services.IService
@inject ICharacterService CharacterService

@if (Visible)
{
    <div class="modal-backdrop">
        <div class="modal-card">
            <header class="modal-header">
                <div>
                    <span class="modal-kicker">Character</span>
                    <h4>@(IsEdit ? "Rediger character" : "Opret character")</h4>
                </div>

                <button class="close-button" @onclick="Close">×</button>
            </header>

            <div class="modal-content">
                <div class="form-grid">
                    <label>
                        <span>Navn</span>

                        <input @bind="Model.Name"
                               placeholder="Characterens navn" />
                    </label>

                    <label>
                        <span>Beskrivelse</span>

                        <textarea @bind="Model.Description"
                                  placeholder="Kort beskrivelse af characteren"></textarea>
                    </label>
                </div>

                <div class="trait-heading">
                    <div>
                        <h5>Grundværdier</h5>
                        <p>
                            Grundværdierne bruges som startværdier,
                            hver gang et nyt spil oprettes.
                        </p>
                    </div>

                    <span class="scale-badge">0 — 100</span>
                </div>

                <div class="trait-grid">
                    @NumberField(
                        "Tjenestemotivation",
                        "Hvor motiveret characteren er ved spillets start.",
                        Model.BaseStats.TjenesteMotivation,
                        value => Model.BaseStats.TjenesteMotivation = value)

                    @NumberField(
                        "Stress",
                        "Hvor stresset characteren er ved spillets start.",
                        Model.BaseStats.Stress,
                        value => Model.BaseStats.Stress = value)

                    @NumberField(
                        "Social lyst",
                        "Hvor stor lyst characteren har til socialt samvær.",
                        Model.BaseStats.Sociallyst,
                        value => Model.BaseStats.Sociallyst = value)

                    @NumberField(
                        "Tillid",
                        "Hvor stor tillid characteren har ved spillets start.",
                        Model.BaseStats.Tillid,
                        value => Model.BaseStats.Tillid = value)
                </div>
            </div>

            <footer class="modal-actions">
                <button class="secondary-button" @onclick="Close">
                    Annuller
                </button>

                <button class="save-button"
                        @onclick="Save"
                        disabled="@string.IsNullOrWhiteSpace(Model.Name)">
                    Gem character
                </button>
            </footer>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }

    [Parameter]
    public Character Model { get; set; } = new();

    private bool IsEdit => !string.IsNullOrWhiteSpace(Model.Id);

    protected override void OnParametersSet()
    {
        Model.BaseStats ??= new BaseStats();
        Model.CurrentStats ??= new CurrentStats();
    }

    private async Task Save()
    {
        ClampValues();

        if (IsEdit)
            await CharacterService.UpdateCharacterAsync(Model.Id, Model);
        else
            await CharacterService.CreateCharacterAsync(Model);

        await VisibleChanged.InvokeAsync(false);
    }

    private async Task Close()
    {
        await VisibleChanged.InvokeAsync(false);
    }

    private void ClampValues()
    {
        Model.BaseStats.TjenesteMotivation =
            Math.Clamp(Model.BaseStats.TjenesteMotivation, 0, 100);

        Model.BaseStats.Stress =
            Math.Clamp(Model.BaseStats.Stress, 0, 100);

        Model.BaseStats.Sociallyst =
            Math.Clamp(Model.BaseStats.Sociallyst, 0, 100);

        Model.BaseStats.Tillid =
            Math.Clamp(Model.BaseStats.Tillid, 0, 100);
    }

    private RenderFragment NumberField(
        string label,
        string description,
        int value,
        Action<int> setValue) => @<label class="trait-field">
        <span class="trait-name">@label</span>

        <input type="number"
               min="0"
               max="100"
               value="@value"
               @onchange="eventArgs => SetValue(eventArgs, setValue)" />

        <small>@description</small>
    </label>;

    private static void SetValue(
        ChangeEventArgs eventArgs,
        Action<int> setValue)
    {
        var parsed = int.TryParse(
            eventArgs.Value?.ToString(),
            out var value);

        setValue(parsed ? Math.Clamp(value, 0, 100) : 0);
    }
}