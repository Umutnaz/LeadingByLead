@using Core
@using Frontend.Services.IService
@inject IQuestionsService QuestionService

@if (Visible)
{
    <div class="modal-backdrop">
        <div class="modal-card">
            <header class="modal-header">
                <div>
                    <span class="modal-kicker">Spørgsmål</span>
                    <h4>@(IsEdit ? "Rediger spørgsmål" : "Opret spørgsmål")</h4>
                </div>

                <button class="close-button" @onclick="Close">×</button>
            </header>

            <div class="modal-content">
                <label class="question-field">
                    <span>Antal svar spilleren skal vælge</span>

                    <input type="number"
                           min="1"
                           max="@Math.Max(1, Model.AnswerOptions.Count)"
                           value="@Model.RequiredSelections"
                           @onchange="ChangeRequiredSelections" />
                </label>

                <section class="options-section">
                    <div class="section-title">
                        <h5>Svarmuligheder</h5>

                        <button class="add-button" @onclick="AddOption">
                            + Tilføj svar
                        </button>
                    </div>

                    @if (Model.AnswerOptions.Count == 0)
                    {
                        <div class="empty-options">
                            Ingen svarmuligheder endnu.
                        </div>
                    }
                    else
                    {
                        <div class="option-list">
                            @foreach (var optionItem in Model.AnswerOptions
                                .Select((value, index) => new { value, index }))
                            {
                                var option = optionItem.value;

                                <article class="option-card option-@(optionItem.index % 5)"
                                         @key="option.Id">

                                    <div class="option-header">
                                        <span class="option-number">
                                            @(optionItem.index + 1)
                                        </span>

                                        <input class="answer-input"
                                               @bind="option.Text"
                                               placeholder="Skriv svarmuligheden" />

                                        <button class="delete-button"
                                                @onclick="() => RemoveOption(option)">
                                            Slet svar
                                        </button>
                                    </div>

                                    <div class="characters-section">
                                        <div class="characters-header">
                                            <div>
                                                <strong>Character-påvirkninger</strong>
                                                <small>
                                                    Klik på en character for at redigere påvirkningen.
                                                </small>
                                            </div>
                                        </div>

                                        @if (Characters.Count == 0)
                                        {
                                            <div class="empty-effects">
                                                Der findes ingen characters endnu.
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="character-effect-list">
                                                @foreach (var character in Characters)
                                                {
                                                    var effect = GetEffect(
                                                        option,
                                                        character.Id);

                                                    <button class="character-effect-row"
                                                            @onclick="() => OpenEffectModal(option, character)">
                                                        <span class="character-name">
                                                            @GetFirstName(character.Name)
                                                        </span>

                                                        <span class="effect-summary">
                                                            @GetEffectSummary(effect)
                                                        </span>

                                                        <span class="edit-effect">
                                                            Rediger
                                                        </span>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>
            </div>

            <footer class="modal-actions">
                <button class="secondary-button" @onclick="Close">
                    Annuller
                </button>

                <button class="save-button"
                        @onclick="Save"
                        disabled="@(!CanSave)">
                    Gem spørgsmål
                </button>
            </footer>
        </div>
    </div>
}

<CharacterEffectsModal Visible="@showEffectsModal"
                       VisibleChanged="value => showEffectsModal = value"
                       Character="@selectedCharacter"
                       Effect="@selectedEffect"
                       Saved="SaveCharacterEffect" />

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }

    [Parameter]
    public Question Model { get; set; } = new();

    [Parameter]
    public IReadOnlyList<Character> Characters { get; set; } =
        Array.Empty<Character>();

    private bool showEffectsModal;
    private Character? selectedCharacter;
    private CharacterEffect? selectedEffect;
    private AnswerOption? selectedOption;

    private bool IsEdit => !string.IsNullOrWhiteSpace(Model.Id);

    private bool CanSave =>
        !string.IsNullOrWhiteSpace(Model.Text) &&
        Model.AnswerOptions.Count > 0 &&
        Model.AnswerOptions.All(
            option => !string.IsNullOrWhiteSpace(option.Text));

    protected override void OnParametersSet()
    {
        Model.AnswerOptions ??= new List<AnswerOption>();

        foreach (var option in Model.AnswerOptions)
            option.CharacterEffects ??= new List<CharacterEffect>();
    }

    private void AddOption()
    {
        Model.AnswerOptions.Add(new AnswerOption
        {
            Id = Guid.NewGuid().ToString(),
            Text = "Ny svarmulighed",
            CharacterEffects = new List<CharacterEffect>()
        });
    }

    private void RemoveOption(AnswerOption option)
    {
        Model.AnswerOptions.Remove(option);

        Model.RequiredSelections = Math.Clamp(
            Model.RequiredSelections,
            1,
            Math.Max(1, Model.AnswerOptions.Count));
    }

    private void OpenEffectModal(
        AnswerOption option,
        Character character)
    {
        selectedOption = option;
        selectedCharacter = character;

        var existingEffect = GetEffect(option, character.Id);

        selectedEffect = existingEffect == null
            ? new CharacterEffect
            {
                CharacterId = character.Id,
                Changes = new List<StatChange>()
            }
            : new CharacterEffect
            {
                CharacterId = existingEffect.CharacterId,

                Changes = existingEffect.Changes
                    .Select(change => new StatChange
                    {
                        StatName = change.StatName,
                        Amount = change.Amount
                    })
                    .ToList()
            };

        showEffectsModal = true;
    }

    private Task SaveCharacterEffect(CharacterEffect effect)
    {
        if (selectedOption == null)
            return Task.CompletedTask;

        selectedOption.CharacterEffects.RemoveAll(
            existing => existing.CharacterId == effect.CharacterId);

        if (effect.Changes.Count > 0)
            selectedOption.CharacterEffects.Add(effect);

        return Task.CompletedTask;
    }

    private static CharacterEffect? GetEffect(
        AnswerOption option,
        string characterId)
    {
        return option.CharacterEffects.FirstOrDefault(
            effect => effect.CharacterId == characterId);
    }

    private static string GetEffectSummary(CharacterEffect? effect)
    {
        if (effect == null || effect.Changes.Count == 0)
            return "Ingen ændringer";

        return string.Join(
            ", ",
            effect.Changes.Select(change =>
                $"{GetStatLabel(change.StatName)} " +
                $"{(change.Amount >= 0 ? "+" : "")}{change.Amount}"));
    }

    private static string GetFirstName(string name)
    {
        return string.IsNullOrWhiteSpace(name)
            ? "Character"
            : name.Split(
                ' ',
                StringSplitOptions.RemoveEmptyEntries).First();
    }

    private static string GetStatLabel(string statName)
    {
        return statName switch
        {
            nameof(CurrentStats.TjenesteMotivation) => "Motivation",
            nameof(CurrentStats.Stress) => "Stress",
            nameof(CurrentStats.Sociallyst) => "Social lyst",
            nameof(CurrentStats.Tillid) => "Tillid",
            _ => statName
        };
    }

    private void NormalizeEffects()
    {
        foreach (var option in Model.AnswerOptions)
        {
            option.CharacterEffects ??= new List<CharacterEffect>();

            option.CharacterEffects = option.CharacterEffects
                .Where(effect =>
                    Characters.Any(
                        character => character.Id == effect.CharacterId))
                .Select(effect => new CharacterEffect
                {
                    CharacterId = effect.CharacterId,

                    Changes = effect.Changes
                        .Where(change => change.Amount != 0)
                        .GroupBy(change => change.StatName)
                        .Select(group => group.Last())
                        .Select(change => new StatChange
                        {
                            StatName = change.StatName,
                            Amount = Math.Clamp(
                                change.Amount,
                                -100,
                                100)
                        })
                        .ToList()
                })
                .Where(effect => effect.Changes.Count > 0)
                .ToList();
        }
    }

    private async Task Save()
    {
        if (!CanSave)
            return;

        NormalizeEffects();

        if (IsEdit)
            await QuestionService.UpdateQuestionAsync(Model.Id, Model);
        else
            await QuestionService.CreateQuestionAsync(Model);

        await VisibleChanged.InvokeAsync(false);
    }

    private async Task Close()
    {
        await VisibleChanged.InvokeAsync(false);
    }
    private void ChangeRequiredSelections(ChangeEventArgs eventArgs)
    {
        if (!int.TryParse(eventArgs.Value?.ToString(), out var value))
            value = 1;

        Model.RequiredSelections = Math.Clamp(
            value,
            1,
            Math.Max(1, Model.AnswerOptions.Count));
    }
}